@page "/support-tasks/api-trn-requests/{supportTaskReference}/resolve/check-answers/{handler?}"
@model TeachingRecordSystem.SupportUi.Pages.SupportTasks.ApiTrnRequests.Resolve.CheckAnswers
@{
    ViewBag.Title = Model.CreatingNewRecord ? "Check details before creating a new record" : "Check details before updating record";

    var backLink = Model.CreatingNewRecord
        ? LinkGenerator.SupportTasks.ApiTrnRequests.Resolve.Matches(Model.SupportTaskReference!, Model.JourneyInstance!.InstanceId)
        : LinkGenerator.SupportTasks.ApiTrnRequests.Resolve.Merge(Model.SupportTaskReference!, Model.JourneyInstance!.InstanceId);
    var changeLink = Model.CreatingNewRecord
        ? LinkGenerator.SupportTasks.ApiTrnRequests.Resolve.Matches(Model.SupportTaskReference!, Model.JourneyInstance!.InstanceId, fromCheckAnswers: true)
        : LinkGenerator.SupportTasks.ApiTrnRequests.Resolve.Merge(Model.SupportTaskReference!, Model.JourneyInstance!.InstanceId, fromCheckAnswers: true);

    var confirmButtonLabel = Model.CreatingNewRecord ? "Confirm and create record" : "Confirm and update existing record";
}

@section BeforeContent {
    <govuk-back-link href="@backLink" />
}


<form action="@LinkGenerator.SupportTasks.ApiTrnRequests.Resolve.CheckAnswers(Model.SupportTaskReference!, Model.JourneyInstance!.InstanceId)" method="post">
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            <span class="govuk-caption-l">TRN requests</span>
            <h1 class="govuk-heading-l">@ViewBag.Title</h1>

            <govuk-summary-list>
                <row>
                    <key>First name</key>
                    <value use-empty-fallback>@Model.FirstName</value>
                    @if (Model.IsFirstNameChangeable)
                    {
                        <row-actions>
                            <action href="@changeLink" data-testid="firstname-change-link" visually-hidden-text="first name">Change</action>
                        </row-actions>
                    }
                </row>
                <row>
                    <key>Middle name</key>
                    <value use-empty-fallback>@Model.MiddleName</value>
                    @if (Model.IsMiddleNameChangeable)
                    {
                        <row-actions>
                            <action href="@changeLink" data-testid="middlename-change-link" visually-hidden-text="middle name">Change</action>
                        </row-actions>
                    }
                </row>
                <row>
                    <key>Last name</key>
                    <value use-empty-fallback>@Model.LastName</value>
                    @if (Model.IsLastNameChangeable)
                    {
                        <row-actions>
                            <action href="@changeLink" data-testid="lastname-change-link" visually-hidden-text="last name">Change</action>
                        </row-actions>
                    }
                </row>
                <row>
                    <key>Date of birth</key>
                    <value use-empty-fallback>@Model.DateOfBirth?.ToString(WebConstants.DateOnlyDisplayFormat)</value>
                    @if (Model.IsDateOfBirthChangeable)
                    {
                        <row-actions>
                            <action href="@changeLink" data-testid="dob-change-link" visually-hidden-text="date of birth">Change</action>
                        </row-actions>
                    }
                </row>
                <row>
                    <key>Email address</key>
                    <value use-empty-fallback>@Model.EmailAddress</value>
                    @if (Model.IsEmailAddressChangeable)
                    {
                        <row-actions>
                            <action href="@changeLink" data-testid="email-change-link" visually-hidden-text="email address">Change</action>
                        </row-actions>
                    }
                </row>
                <row>
                    <key>National Insurance number</key>
                    <value use-empty-fallback>@Model.NationalInsuranceNumber</value>
                    @if (Model.IsNationalInsuranceNumberChangeable)
                    {
                        <row-actions>
                            <action href="@changeLink" data-testid="ni-change-link" visually-hidden-text="national insurance number">Change</action>
                        </row-actions>
                    }
                </row>
                <row>
                    <key>Gender</key>
                    <value use-empty-fallback>@Model.Gender?.GetDisplayName()</value>
                    @if (Model.IsGenderChangeable)
                    {
                        <row-actions>
                            <action href="@changeLink" data-testid="gender-change-link" visually-hidden-text="gender">Change</action>
                        </row-actions>
                    }
                </row>
                @if (Model.Trn is not null)
                {
                    <row>
                        <key>TRN</key>
                        <value>@Model.Trn</value>
                        <row-actions>
                            <action href="@changeLink" data-testid="change-link" visually-hidden-text="trn">Change</action>
                        </row-actions>
                    </row>
                }

                @if (Model.CreatingNewRecord == false)
                {
                    <row>
                        <key>Comments</key>
                        <value use-empty-fallback>@Model.Comments</value>
                        <row-actions>
                            <action href="@changeLink" data-testid="comments-change-link" visually-hidden-text="comments">Change</action>
                        </row-actions>
                    </row>
                }
            </govuk-summary-list>


            <div class="govuk-button-group">
                <govuk-button type="submit">@confirmButtonLabel</govuk-button>
                <govuk-button type="submit" formaction="@LinkGenerator.SupportTasks.ApiTrnRequests.Resolve.CheckAnswersCancel(Model.SupportTaskReference!, Model.JourneyInstance!.InstanceId)" class="govuk-button--secondary">Cancel</govuk-button>
            </div>
        </div>
    </div>
</form>

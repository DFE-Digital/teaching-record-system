@page "/support-tasks/one-login-user-matching/{supportTaskReference}/resolve/confirm-connect"
@model TeachingRecordSystem.SupportUi.Pages.SupportTasks.OneLoginUserMatching.Resolve.ConfirmConnect
@{
    ViewBag.Title = "Check details before connecting this GOV.UK One Login";
}

@section BeforeContent {
    <govuk-back-link href="@LinkGenerator.SupportTasks.OneLoginUserMatching.Resolve.Matches(Model.SupportTaskReference, Model.JourneyInstance.InstanceId)" />
}

<form method="post">
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            <span class="govuk-caption-l">Record management</span>
            <h1 class="govuk-heading-l">@ViewBag.Title</h1>

            <govuk-inset-text>
                We’ll send @Model.MatchedPersonName an email confirming their GOV.UK One Login has been connected to their teaching record.
            </govuk-inset-text>

            <h2 class="govuk-heading-s">GOV.UK One Login details</h2>

            <govuk-summary-list data-testid="one-login-user-details">
                <row>
                    <key>Email address</key>
                    <value>@Model.OneLoginUserEmailAddress</value>
                </row>
            </govuk-summary-list>

            <govuk-summary-card data-testid="matched-person-details">
                <title>Record details</title>
                <card-actions>
                    <govuk-summary-card-action href="@LinkGenerator.Persons.PersonDetail.Index(Model.MatchedPersonId)" target="_blank">
                        View record (opens in a new tab)
                    </govuk-summary-card-action>
                </card-actions>
                <govuk-summary-list>
                    <row>
                        <key>Name</key>
                        <value>@Model.MatchedPersonName</value>
                    </row>
                    @if (Model.MatchedPersonPreviousNames!.Count > 0)
                    {
                        <row>
                            <key>Previous names</key>
                            <value>
                                <list-text-items text-items="@Model.MatchedPersonPreviousNames"></list-text-items>
                            </value>
                        </row>
                    }
                    <row>
                        <key>Email address</key>
                        <value use-empty-fallback>@Model.MatchedPersonEmailAddress</value>
                    </row>
                    <row>
                        <key>Date of birth</key>
                        <value>@Model.MatchedPersonDateOfBirth.ToString(WebConstants.DateOnlyDisplayFormat)</value>
                    </row>
                    <row>
                        <key>TRN</key>
                        <value>@Model.MatchedPersonTrn</value>
                    </row>
                    <row>
                        <key>National Insurance number</key>
                        <value use-empty-fallback>@Model.MatchedPersonNationalInsuranceNumber</value>
                    </row>
                </govuk-summary-list>
            </govuk-summary-card>

            <div class="govuk-button-group">
                <govuk-button type="submit">Confirm and connect account</govuk-button>
                <govuk-button type="submit" name="Cancel" value="true" class="govuk-button--secondary">Cancel</govuk-button>
            </div>
        </div>
    </div>
</form>

@using TeachingRecordSystem.Core.Events
@using TeachingRecordSystem.Core.Services.Files
@inject IFileService FileService
@model TimelineItem<TimelineEvent<TeachingRecordSystem.Core.Events.Legacy.PersonStatusUpdatedEvent>>
@{
    var statusUpdatedEvent = Model.ItemModel.Event;
    var (actionPastParticiple, actionNoun) = statusUpdatedEvent.Status == PersonStatus.Deactivated
        ? ("deactivated", "deactivation")
        : ("reactivated", "reactivation");
    var evidenceFileUrl = statusUpdatedEvent.EvidenceFile is not null
        ? await FileService.GetFileUrlAsync(statusUpdatedEvent.EvidenceFile!.FileId, TimeSpan.FromMinutes(15))
        : null;
}
<div class="moj-timeline__item govuk-!-padding-bottom-2" data-testid="timeline-item-status-updated-event">
    <div class="moj-timeline__header">
        <h2 class="moj-timeline__title">Record @actionPastParticiple</h2>
    </div>
    <p class="moj-timeline__date">
        <span data-testid="raised-by">By @Model.ItemModel.RaisedByUser.Name on</span>
        <time datetime="@Model.Timestamp.ToString("O")" data-testid="timeline-item-time">@Model.FormattedTimestamp</time>
    </p>
    <div class="moj-timeline__description">
        <govuk-details class="govuk-!-margin-bottom-2" data-testid="change-reason">
            <govuk-details-summary>Reason for @actionNoun</govuk-details-summary>
            <govuk-details-text>
                <govuk-summary-list>
                    <row>
                        <key>Reason</key>
                        <value use-empty-fallback>@statusUpdatedEvent.Reason</value>
                    </row>
                    <row>
                        <key>Reason details</key>
                        <value>
                            @if (statusUpdatedEvent.ReasonDetail is not null)
                            {
                                @Html.ConvertNewlinesToLineBreaks(statusUpdatedEvent.ReasonDetail)
                            }
                            else
                            {
                                <span use-empty-fallback></span>
                            }
                        </value>
                    </row>
                    <row>
                        <key>Evidence</key>
                        <value>
                            <vc:event-evidence-file-link evidence-file="@statusUpdatedEvent.EvidenceFile" />
                        </value>
                    </row>
                </govuk-summary-list>
            </govuk-details-text>
        </govuk-details>
    </div>
</div>

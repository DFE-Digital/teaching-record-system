@using Optional.Unsafe
@using TeachingRecordSystem.Core.Events
@using TeachingRecordSystem.Core.Services.Files
@inject ReferenceDataCache ReferenceDataCache
@model TimelineItem<TimelineEvent<TeachingRecordSystem.Core.Events.Legacy.InductionMigratedEvent>>
@{
    var migratedEvent = Model.ItemModel.Event;
    var dqtInduction = migratedEvent.DqtInduction;
}

<div class="moj-timeline__item govuk-!-padding-bottom-2" data-testid="timeline-item-induction-migrated-event">
    <div class="moj-timeline__header">
        <h2 class="moj-timeline__title">Induction migrated</h2>
    </div>
    <p class="moj-timeline__date">
        <span data-testid="raised-by">By @Model.ItemModel.RaisedByUser.Name on</span>
        <time datetime="@Model.Timestamp.ToString("O")" data-testid="timeline-item-time">@Model.FormattedTimestamp</time>
    </p>
    <div class="moj-timeline__description">
        <govuk-summary-list>
            <row>
                <key>Induction status</key>
                <value data-testid="induction-status">@migratedEvent.InductionStatus.GetTitle()</value>
            </row>
            @if (migratedEvent.InductionExemptionReasonId is Guid exemptionReasonId)
            {
                var exemptionReason = await ReferenceDataCache.GetInductionExemptionReasonByIdAsync(exemptionReasonId);
                <row>
                    <key>Induction exemption reason</key>
                    <value data-testid="exemption-reason">@exemptionReason.Name</value>
                </row>
            }
            @if (migratedEvent.InductionStartDate.HasValue)
            {
                <row>
                    <key>Started on</key>
                    <value data-testid="start-date">@migratedEvent.InductionStartDate?.ToString(WebConstants.DateOnlyDisplayFormat)</value>
                </row>
            }
            @if (migratedEvent.InductionCompletedDate.HasValue)
            {
                <row>
                    <key>Completed on</key>
                    <value data-testid="completed-date">@migratedEvent.InductionCompletedDate?.ToString(WebConstants.DateOnlyDisplayFormat)</value>
                </row>
            }
        </govuk-summary-list>
        <govuk-details class="govuk-!-margin-bottom-2" data-testid="previous-data">
            <govuk-details-summary>Previous data</govuk-details-summary>
            <govuk-details-text>
                <govuk-summary-list>
                    <row>
                        <key>DQT induction status</key>
                        <value data-testid="dqt-induction-status">@migratedEvent.DqtInductionStatus</value>
                    </row>
                    @if (dqtInduction?.InductionExemptionReason.HasValue == true)
                    {
                        <row>
                            <key>DQT induction exemption reason</key>
                            <value data-testid="dqt-exemption-reason">@dqtInduction.InductionExemptionReason.ValueOrDefault()</value>
                        </row>
                    }
                </govuk-summary-list>
            </govuk-details-text>
        </govuk-details>
    </div>
</div>

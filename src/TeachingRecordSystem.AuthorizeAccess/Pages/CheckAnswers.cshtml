@page "/check-answers"
@inject SignInJourneyCoordinator.LinkHelper Links
@using Microsoft.AspNetCore.Http.Extensions
@model TeachingRecordSystem.AuthorizeAccess.Pages.CheckAnswersModel
@{
    ViewBag.Title = "Check your details before sending support request";
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <form method="post">
            <h1 class="govuk-heading-l">@ViewBag.Title</h1>

            <h2 class="govuk-heading-m">GOV.UK One Login details</h2>

            <govuk-summary-list>
                <row>
                    <key>Email address</key>
                    <value>@Model.Email</value>
                </row>
                @if (Model.IdentityVerified)
                {
                    <row>
                        <key>Name</key>
                        <value>@Model.Name</value>
                    </row>
                    <row>
                        <key>Date of birth</key>
                        <value>@Model.DateOfBirth.ToString("d MMMM yyyy")</value>
                    </row>
                }
            </govuk-summary-list>

            <h2 class="govuk-heading-m">Additional details</h2>

            <govuk-summary-list>
                @if (!Model.IdentityVerified)
                {
                    <row>
                        <key>Name</key>
                        <value>@Model.Name</value>
                        <row-actions>
                            <action href="@Links.Name(returnUrl: Request.GetEncodedPathAndQuery())"
                                                           visually-hidden-text="name">
                                Change
                            </action>
                        </row-actions>
                    </row>
                    <row>
                        <key>Date of birth</key>
                        <value>@Model.DateOfBirth.ToString("d MMMM yyyy")</value>
                        <row-actions>
                            <action href="@Links.DateOfBirth(returnUrl: Request.GetEncodedPathAndQuery())"
                                                           visually-hidden-text="date of birth">
                                Change
                            </action>
                        </row-actions>
                    </row>
                }
                <row>
                    <key>
                        National Insurance number
                    </key>
                    <value use-empty-fallback>@Model.NationalInsuranceNumber</value>
                    <row-actions>
                        <action href="@Links.NationalInsuranceNumber(returnUrl: Request.GetEncodedPathAndQuery())"
                                                       visually-hidden-text="National Insurance number">
                            Change
                        </action>
                    </row-actions>
                </row>
                <row>
                    <key>
                        TRN
                    </key>
                    <value use-empty-fallback>@Model.Trn</value>
                    <row-actions>
                        <action href="@Links.Trn(returnUrl: Request.GetEncodedPathAndQuery())"
                                                       visually-hidden-text="teacher reference number">
                            Change
                        </action>
                    </row-actions>
                </row>
                @if (!Model.IdentityVerified)
                {
                    <row>
                        <key>
                            Proof of identity
                        </key>
                        <value use-empty-fallback>@Model.ProofOfIdentityFileName</value>
                        <row-actions>
                            <action href="@Links.ProofOfIdentity(returnUrl: Request.GetEncodedPathAndQuery())"
                                                           visually-hidden-text="proof of identity">
                                Change
                            </action>
                        </row-actions>
                    </row>
                }
            </govuk-summary-list>

            <govuk-button type="submit">Submit support request</govuk-button>
        </form>
    </div>
</div>

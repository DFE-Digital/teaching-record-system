@using Htmx.TagHelpers
@using Joonasw.AspNetCore.SecurityHeaders.Csp
@using Microsoft.AspNetCore.Authorization;
@using TeachingRecordSystem.SupportUi.Infrastructure.Security;
@addTagHelper *, Joonasw.AspNetCore.SecurityHeaders
@inject IAuthorizationService AuthorizationService
@inject IWebHostEnvironment Environment
@{
    Layout = "_GovUkPageTemplate";
    ViewBag.Title = ViewBag.Title + (ViewBag.Title is not null ? " - " : "") + "Teaching record system";

    var headerClass = Environment.IsDevelopment() ? "trs-header--local" :
        System.Environment.GetEnvironmentVariable("ENVIRONMENT_NAME") is string aksEnvName ? $"trs-header--{aksEnvName}" :
        null;

    var cspService = Context.RequestServices.GetRequiredService<ICspNonceService>();
    var cspNonce = ViewBag.CspNonce = cspService.GetNonce();
}

@section Head {
    <meta name="robots" content="noindex">
    <meta name="htmx-config" includeAspNetAntiforgeryToken="true" includeIndicatorStyles="false">
    <link rel="stylesheet" href="~/app.css">
    @await RenderSectionAsync("Styles", required: false)
    <link rel="stylesheet" href="~/Components/accessible-autocomplete.min.css">
    <link rel="stylesheet" href="~/moj-frontend-9.0.0.min.css">
    <script src="~/Components/accessible-autocomplete.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/htmx.min.js"></script>
    <script src="@HtmxAntiforgeryScriptEndpoints.Path" defer></script>
}

@section GovUkHeader {
    <govuk-header class="trs-header @headerClass">
        <a href="@LinkGenerator.SignOut()" class="trs-header__item">Sign out</a>
    </govuk-header>
}

@section GovUkServiceNavigation {
    <govuk-service-navigation service-name="Teaching record system" service-url="/">
        <govuk-service-navigation-nav>
            @if (User.Identity?.IsAuthenticated == true && User.IsActiveTrsUser())
            {
                <govuk-service-navigation-nav-item
                    href="@LinkGenerator.Index()"
                    current="@(Context.Request.Path == "/")"
                    active="@(Context.Request.Path.StartsWithSegments("/persons"))">
                    Records
                </govuk-service-navigation-nav-item>

                if ((await AuthorizationService.AuthorizeAsync(User, AuthorizationPolicies.UserManagement)).Succeeded)
                {
                    <govuk-service-navigation-nav-item
                        href="@LinkGenerator.Users.Index()"
                        current="@(Context.Request.Path == "/users")"
                        active="@(Context.Request.Path.StartsWithSegments("/users"))">
                        Add and manage users
                    </govuk-service-navigation-nav-item>
                }

                if ((await AuthorizationService.AuthorizeAsync(User, AuthorizationPolicies.AdminOnly)).Succeeded)
                {
                    <govuk-service-navigation-nav-item
                        href="@LinkGenerator.ApplicationUsers.Index()"
                        current="@(Context.Request.Path == "/application-users")"
                        active="@(Context.Request.Path.StartsWithSegments("/application-users") || Context.Request.Path.StartsWithSegments("/api-keys"))">
                        Application users
                    </govuk-service-navigation-nav-item>
                }
            }
        </govuk-service-navigation-nav>
    </govuk-service-navigation>
}

@section BeforeContent {
    @await RenderSectionAsync("BeforeContent", required: false)
}

@if (TempData.TryGetFlashNotificationBanner(out var notificationBanner))
{
    <govuk-notification-banner type="notificationBanner.Value.NotificationBannerType">
        @if (notificationBanner.Value.Heading is string heading)
        {
            <h3 class="govuk-notification-banner__heading">@heading</h3>
        }
        @if (notificationBanner.Value.MessageText is string messageText)
        {
            @foreach (var line in messageText.Split("\n", StringSplitOptions.RemoveEmptyEntries))
            {
                <p class="govuk-body">@line</p>
            }
        }
        else if (notificationBanner.Value.MessageHtml is string messageHtml)
        {
            @Html.Raw(messageHtml)
        }
    </govuk-notification-banner>
}

@RenderBody()

@section GovUkFooter {
    <govuk-footer>
        <govuk-footer-meta>
            <govuk-footer-meta-items>
                <govuk-footer-meta-item href="https://accessibility-statements.education.gov.uk/s/40">Accessibility</govuk-footer-meta-item>
            </govuk-footer-meta-items>
        </govuk-footer-meta>
    </govuk-footer>
}

@section BodyEnd {
    @{
        var assetCollection = Context.GetEndpoint()!.Metadata.GetMetadata<Microsoft.AspNetCore.Components.ResourceAssetCollection>()!;

        var govukFrontend = GetFingerprintedAssetUrl("govuk-frontend.min.js");
        var mojFrontend = GetFingerprintedAssetUrl("moj-frontend-9.0.0.min.js");

        var imports = new Dictionary<string, string>()
        {
            { "govuk-frontend", govukFrontend },
            { "moj-frontend", mojFrontend }
        };

        var importMap = new Microsoft.AspNetCore.Components.ImportMapDefinition(
            imports: imports,
            scopes: null,
            integrity: null);

        string GetFingerprintedAssetUrl(string url) =>
            "/" + assetCollection.Single(a => a.Properties?.Any(p => p.Name == "label" && p.Value == url) is true).Url;
    }
    <script type="importmap" asp-importmap="@importMap" asp-add-nonce="true"></script>
    <script type="module" asp-add-nonce="true">
        import * as GOVUKFrontend from "govuk-frontend";
        import * as MOJFrontend from "moj-frontend";
        GOVUKFrontend.initAll();
        MOJFrontend.initAll();

        document.addEventListener("htmx:afterSwap", function(evt) {
            var el = evt.detail.elt;
            GOVUKFrontend.initAll(el);
            MOJFrontend.initAll(el);
        });
    </script>

}

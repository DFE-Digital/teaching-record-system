@using Optional.Unsafe
@using TeachingRecordSystem.Core.Events
@using TeachingRecordSystem.Core.Services.Files
@inject IFileService FileService
@inject ReferenceDataCache ReferenceDataCache
@model TimelineItem<LegacyEventChangeHistoryEntry<TeachingRecordSystem.Core.Events.Legacy.DqtInductionCreatedEvent>>
@{
    var dqtCreatedEvent = Model.ItemModel.Event;
    var induction = dqtCreatedEvent.Induction;
}

<div class="moj-timeline__item govuk-!-padding-bottom-2" data-testid="timeline-item-dqt-induction-created-event">
    <div class="moj-timeline__header">
        <h2 class="moj-timeline__title">Induction created</h2>
    </div>
    <p class="moj-timeline__date">
        <span data-testid="raised-by">By @Model.ItemModel.RaisedByUser.Name on</span>
        <time datetime="@Model.Timestamp.ToString("O")" data-testid="timeline-item-time">@Model.FormattedGmtTimestamp</time>
    </p>
    <div class="moj-timeline__description">
        <govuk-summary-list>
            @if (induction.InductionStatus.HasValue)
            {
                <row>
                    <key>Induction status</key>
                    <value data-testid="induction-status">@induction.InductionStatus.ValueOrDefault()</value>
                </row>
            }
            @if (induction.InductionExemptionReason.HasValue)
            {
                <row>
                    <key>Exemption reason</key>
                    <value data-testid="exemption-reason">@induction.InductionExemptionReason.ValueOrDefault()</value>
                </row>
            }
            @if (induction.StartDate.HasValue)
            {
                <row>
                    <key>Started on</key>
                    <value data-testid="start-date">@induction.StartDate.ValueOrDefault()?.ToString(WebConstants.DateDisplayFormat)</value>
                </row>
            }
            @if (induction.CompletionDate.HasValue)
            {
                <row>
                    <key>Completed on</key>
                    <value data-testid="completion-date">@induction.CompletionDate.ValueOrDefault()?.ToString(WebConstants.DateDisplayFormat)</value>
                </row>
            }
        </govuk-summary-list>
    </div>
</div>

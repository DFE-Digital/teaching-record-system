@using TeachingRecordSystem.Core.Events
@using TeachingRecordSystem.Core.Services.Files
@inject IFileService FileService
@model TimelineItem<LegacyEventChangeHistoryEntry<TeachingRecordSystem.Core.Events.Legacy.PersonCreatedEvent>>
@{
    var createdEvent = Model.ItemModel.Event;
    var details = createdEvent.PersonAttributes;
    var name = StringHelper.JoinNonEmpty(' ', details.FirstName, details.MiddleName, details.LastName);
    var email = EmailAddress.TryParse(details.EmailAddress, out var parsedEmail)
        ? parsedEmail.ToDisplayString()
        : details.EmailAddress;
    var nino = NationalInsuranceNumber.TryParse(details.NationalInsuranceNumber, out var parsedNino)
        ? parsedNino.ToDisplayString()
        : details.NationalInsuranceNumber;
    var evidenceFileUrl = createdEvent.EvidenceFile is not null
        ? await FileService.GetFileUrlAsync(createdEvent.EvidenceFile!.FileId, TimeSpan.FromMinutes(15))
        : null;
}
<div class="moj-timeline__item govuk-!-padding-bottom-2" data-testid="timeline-item-created-event">
    <div class="moj-timeline__header">
        <h2 class="moj-timeline__title">Record created</h2>
    </div>
    <p class="moj-timeline__date">
        <span data-testid="raised-by">By @Model.ItemModel.RaisedByUser.Name on</span>
        <time datetime="@Model.Timestamp.ToString("O")" data-testid="timeline-item-time">@Model.FormattedGmtTimestamp</time>
    </p>
    <div class="moj-timeline__description">
        <div data-testid="details">
            <govuk-summary-list>
                    <row>
                        <key>Name</key>
                        <value use-empty-fallback>@name</value>
                    </row>
                    <row>
                        <key>Date of birth</key>
                        <value use-empty-fallback>@details.DateOfBirth?.ToString(WebConstants.DateDisplayFormat)</value>
                    </row>
                    @if (email is not null)
                    {
                        <row>
                            <key>Email address</key>
                            <value use-empty-fallback>@email</value>
                        </row>
                    }
                    @if (nino is not null)
                    {
                        <row>
                            <key>National Insurance number</key>
                            <value use-empty-fallback>@nino</value>
                        </row>
                    }
                    @if (details.Gender is not null)
                    {
                        <row>
                            <key>Gender</key>
                            <value use-empty-fallback>@details.Gender?.GetDisplayName()</value>
                        </row>
                    }
            </govuk-summary-list>
        </div>

        <govuk-details class="govuk-!-margin-bottom-2" data-testid="create-reason">
            <govuk-details-summary>Reason for creating record</govuk-details-summary>
            <govuk-details-text>
                <govuk-summary-list>
                        <row>
                            <key>Reason</key>
                            <value use-empty-fallback>@createdEvent.CreateReason</value>
                        </row>
                        <row>
                            <key>Reason details</key>
                            <value>
                                @if (createdEvent.CreateReasonDetail is not null)
                                {
                                    @Html.ConvertNewlinesToLineBreaks(createdEvent.CreateReasonDetail)
                                }
                                else
                                {
                                    <span use-empty-fallback></span>
                                }
                            </value>
                        </row>
                        <row>
                            <key>Additional information</key>
                            <value>
                                @if (createdEvent.CreateAdditionalInformation is not null)
                                {
                                    @Html.ConvertNewlinesToLineBreaks(createdEvent.CreateAdditionalInformation)
                                }
                                else
                                {
                                    <span use-empty-fallback></span>
                                }
                            </value>
                        </row>
                        <row>
                            <key>Evidence</key>
                            <value>
                            <vc:event-evidence-file-link evidence-file="@createdEvent.EvidenceFile" />
                            </value>
                        </row>
                </govuk-summary-list>
            </govuk-details-text>
        </govuk-details>
    </div>
</div>

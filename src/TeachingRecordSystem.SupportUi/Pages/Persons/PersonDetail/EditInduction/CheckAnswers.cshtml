@page "/persons/{PersonId}/edit-induction/check-answers"
@model TeachingRecordSystem.SupportUi.Pages.Persons.PersonDetail.EditInduction.CheckAnswersModel
@{
    ViewBag.Title = "Check your details before updating induction details’";
}

@section BeforeContent {
    <govuk-back-link data-testid="back-link" href="@Model.BackLink">Back</govuk-back-link>
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <form method="post">
            <span class="govuk-caption-l">Edit induction details - @Model.PersonName</span>
            <h1 class="govuk-heading-l">@ViewBag.Title</h1>

            <govuk-summary-list data-testid="change-summary">
                <row>
                    <key>Status</key>
                    <value>@Model.InductionStatus.GetTitle()</value>
                    @if (Model.ShowStatusChangeLink)
                    {
                        <row-actions>
                            <action
                                href="@LinkGenerator.Persons.PersonDetail.EditInduction.Status(Model.PersonId, Model.JourneyInstance!.InstanceId, fromCheckAnswers: JourneyFromCheckAnswersPage.CheckAnswers)"
                                visually-hidden-text="induction status">Change</action>
                        </row-actions>
                    }
                    </row>
                @if (Model.InductionStatus.RequiresStartDate())
                {
                    <row>
                        <key>Start date</key>
                        <value use-empty-fallback>@Model.StartDate?.ToString(WebConstants.DateOnlyDisplayFormat)</value>
                        @if (Model.ShowStartDateChangeLink)
                        {
                            <row-actions>
                                <action
                                href="@LinkGenerator.Persons.PersonDetail.EditInduction.StartDate(Model.PersonId, Model.JourneyInstance!.InstanceId, fromCheckAnswers: JourneyFromCheckAnswersPage.CheckAnswers)"                              visually-hidden-text="start date">Change</action>
                            </row-actions>
                        }
                    </row>
                }
                @if (Model.InductionStatus.RequiresCompletedDate())
                {
                    <row>
                        <key>Completion date</key>
                        <value use-empty-fallback>@Model.CompletedDate?.ToString(WebConstants.DateOnlyDisplayFormat)</value>
                        @if (Model.ShowCompletedDateChangeLink)
                        {
                            <row-actions>
                                <action
                                href="@LinkGenerator.Persons.PersonDetail.EditInduction.CompletedDate(Model.PersonId, Model.JourneyInstance!.InstanceId, fromCheckAnswers: JourneyFromCheckAnswersPage.CheckAnswers)"                              visually-hidden-text="completed date">Change</action>
                            </row-actions>
                        }
                    </row>
                }
                @if(Model.InductionStatus.RequiresExemptionReasons())
                {
                    <row class="govuk-list--spaced">
                        <key>Exemption reason</key>
                        <value>
                            @if (Model.SelectedExemptionReasonsValues is not null)
                            {
                                <ul class="govuk-list">
                                    @foreach (var exemptionReason in Model.SelectedExemptionReasonsValues)
                                    {
                                        <li>@exemptionReason</li>
                                    }
                                </ul>
                            }
                        </value>
                        @if (Model.ShowExemptionReasonsChangeLink)
                        {
                            <row-actions>
                                <action
                                href="@LinkGenerator.Persons.PersonDetail.EditInduction.ExemptionReasons(Model.PersonId, Model.JourneyInstance!.InstanceId, fromCheckAnswers: JourneyFromCheckAnswersPage.CheckAnswers)"                              visually-hidden-text="exemption reason">Change</action>
                            </row-actions>
                        }
                    </row>
                }
                <row>
                    <key>Reason for changing induction details</key>
                    <value>@Model.ChangeReason.GetDisplayName()</value>
                    <row-actions>
                        <action
                        href="@LinkGenerator.Persons.PersonDetail.EditInduction.Reason(Model.PersonId, Model.JourneyInstance!.InstanceId, fromCheckAnswers: JourneyFromCheckAnswersPage.CheckAnswers)"
                        visually-hidden-text="reason for change">Change</action>
                    </row-actions>
                </row>
                <row>
                    <key>Reason details</key>
                    <value>
                        @if (Model.ChangeReasonDetail is not null)
                        {
                            @Html.ConvertNewlinesToLineBreaks(Model.ChangeReasonDetail)
                        }
                        else
                        {
                            <span use-empty-fallback></span>
                        }
                    </value>
                    <row-actions>
                        <action
                            href="@LinkGenerator.Persons.PersonDetail.EditInduction.Reason(Model.PersonId, Model.JourneyInstance!.InstanceId, fromCheckAnswers: JourneyFromCheckAnswersPage.CheckAnswers)"
                            visually-hidden-text="reason details">Change</action>
                    </row-actions>
                </row>
            </govuk-summary-list>

            <h2 class="govuk-heading-m">Why are you editing these induction details?</h2>
            <govuk-summary-list>
                <row>
					<key>Reason</key>
					<value>@Model.ChangeReason.GetDisplayName()</value>
					<row-actions>
						<action
						href="@LinkGenerator.Persons.PersonDetail.EditInduction.Reason(Model.PersonId, Model.JourneyInstance!.InstanceId, fromCheckAnswers: JourneyFromCheckAnswersPage.CheckAnswers)"
						visually-hidden-text="reason for change">Change</action>
					</row-actions>
				</row>
				<row>
					<key>Additional information</key>
					<value>
						@if (Model.ChangeReasonDetail is not null)
						{
							@Html.ConvertNewlinesToLineBreaks(Model.ChangeReasonDetail)
						}
						else
						{
							<span use-empty-fallback></span>
						}
					</value>
					<row-actions>
						<action
							href="@LinkGenerator.Persons.PersonDetail.EditInduction.Reason(Model.PersonId, Model.JourneyInstance!.InstanceId, fromCheckAnswers: JourneyFromCheckAnswersPage.CheckAnswers)"
							visually-hidden-text="reason details">Change</action>
					</row-actions>
				</row>
				<row>
					<key>Evidence</key>
					<value>
						<vc:evidence-file-link evidence-file="@Model.EvidenceFile" />
					</value>
					<row-actions>
						<action
							href="@LinkGenerator.Persons.PersonDetail.EditInduction.Reason(Model.PersonId, Model.JourneyInstance!.InstanceId, fromCheckAnswers: JourneyFromCheckAnswersPage.CheckAnswers)"
							visually-hidden-text="evidence">Change</action>
					</row-actions>
				</row>
            </govuk-summary-list>

            <div class="govuk-button-group">
                <govuk-button type="submit" data-testid="confirm-button">Confirm induction details</govuk-button>
                <govuk-button data-testid="cancel-button" formaction="@LinkGenerator.Persons.PersonDetail.EditInduction.CheckAnswersCancel(Model.PersonId, Model.JourneyInstance!.InstanceId)" class="govuk-button--secondary" type="submit">Cancel and return to record</govuk-button>
            </div>
        </form>
    </div>
</div>

@page "/support-tasks/integration-transactions/{integrationTransactionId}/detail/{handler?}"
@addTagHelper *, Joonasw.AspNetCore.SecurityHeaders
@model TeachingRecordSystem.SupportUi.Pages.SupportTasks.IntegrationTransactions.DetailModel
@{
    ViewBag.Title = "Interfaces";
}

@section BeforeContent {
    <govuk-back-link href="@LinkGenerator.SupportTasks.IntegrationTransactions.Index()" />
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <span class="govuk-caption-l">Third-party tasks</span>
        <h1 class="govuk-heading-l" data-testid="integration-transaction-interface-type">@Model.IntegrationTransaction!.InterfaceType.GetDisplayName() - File details</h1>
    </div>

    @if (Model.IntegrationTransaction.ImportStatus == IntegrationTransactionImportStatus.Failed)
    {
        <div class="govuk-grid-column-full govuk-body-m ">
            <div class="govuk-error-message govuk-!-padding-1 govuk-!-padding-top-2 govuk-!-padding-left-2 trs-itr-transaction-error">
            <h1 class="govuk-heading-l">Upload unsuccessful</h1>
            <p class="govuk-body-m">
                The file loaded incorrectly due to invalid formatting.
            </p>
            <p class="govuk-body-m">
                You need to fix the formatting and re-upload the file.
            </p>
        </div>
    </div>
    }

    <div class="govuk-grid-column-full">
        <govuk-summary-card data-testid="integration-record">
            <title>Record information</title>
            <govuk-summary-list>
                <row>
                    <key>Date and time</key>
                    <value>@Model.IntegrationTransaction!.CreatedOn.ToString(WebConstants.DateTimeDisplayFormat)</value>
                </row>
                <row>
                    <key>File name</key>
                    <value use-empty-fallback>@Model.IntegrationTransaction!.FileName</value>
                </row>
                <row>
                    <key>Interface ID</key>
                    <value use-empty-fallback>@Model.IntegrationTransaction!.IntegrationTransactionId</value>
                </row>
                <row>
                    <key>Total count</key>
                    <value use-empty-fallback>@Model.IntegrationTransaction!.TotalCount</value>
                </row>
                <row>
                    <key>Successes</key>
                    <value use-empty-fallback>@Model.IntegrationTransaction!.SuccessesCount</value>
                </row>
                <row>
                    <key>Warnings</key>
                    <value use-empty-fallback>@Model.IntegrationTransaction!.WarningsCount</value>
                </row>
                <row>
                    <key>Failures</key>
                    <value use-empty-fallback>@Model.IntegrationTransaction!.FailuresCount</value>
                </row>
                <row>
                    <key>Duplicates</key>
                    <value use-empty-fallback>@Model.IntegrationTransaction!.DuplicatesCount</value>
                </row>
            </govuk-summary-list>
        </govuk-summary-card>


        @if (Model.HasFailures)
        {
            <div data-testid="export-integration-record-failures">
                <govuk-button-link asp-page-handler="DownloadFailures">
                    Export failures
                </govuk-button-link>
            </div>
        }

        <div class="govuk-grid-column-full" data-testid="results">
            <table class="govuk-table">
                <thead class="govuk-table__head">
                    <tr class="govuk-table__row">
                        <th scope="col" class="govuk-table__header"
                            sort-direction="@(Model.SortBy == IntegrationTransactionRecordSortByOption.IntegrationTransactionRecordId ? Model.SortDirection : null)"
                            link-template="@(direction => LinkGenerator.SupportTasks.IntegrationTransactions.Detail(IntegrationTransactionRecordSortByOption.IntegrationTransactionRecordId,  direction, pageNumber: null, Model.IntegrationTransactionId))">
                            ID
                        </th>

                        <th scope="col" class="govuk-table__header"
                            sort-direction="@(Model.SortBy == IntegrationTransactionRecordSortByOption.Name ? Model.SortDirection : null)"
                            link-template="@(direction => LinkGenerator.SupportTasks.IntegrationTransactions.Detail(IntegrationTransactionRecordSortByOption.Name,  direction, pageNumber: null, Model.IntegrationTransactionId))">
                            Person
                        </th>
                        <th scope="col" class="govuk-table__header"
                            sort-direction="@(Model.SortBy == IntegrationTransactionRecordSortByOption.Duplicate ? Model.SortDirection : null)"
                            link-template="@(direction => LinkGenerator.SupportTasks.IntegrationTransactions.Detail(IntegrationTransactionRecordSortByOption.Duplicate,  direction, pageNumber: null, Model.IntegrationTransactionId))">
                            Duplicate
                        </th>
                        <th scope="col" class="govuk-table__header"
                            sort-direction="@(Model.SortBy == IntegrationTransactionRecordSortByOption.Status ? Model.SortDirection : null)"
                            link-template="@(direction => LinkGenerator.SupportTasks.IntegrationTransactions.Detail(IntegrationTransactionRecordSortByOption.Status,  direction, pageNumber: null, Model.IntegrationTransactionId))">
                            Status
                        </th>
                    </tr>
                </thead>
                <tbody class="govuk-table__body">
                    @if (Model.IntegrationTransactionRecords!.Count == 0)
                    {
                        <tr class="govuk-table__row" data-testid="no-integration-transaction-records-message">
                            <td class="govuk-table__cell" colspan="4">No integration transaction records</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var result in Model.IntegrationTransactionRecords)
                        {
                            <tr class="govuk-table__row" data-testid="integration-transaction-record:@result.IntegrationTransactionRecordId">
                                <td class="govuk-table__cell"
                                    data-testid="integration-transaction-record:@result.IntegrationTransactionRecordId:id">
                                    @result.IntegrationTransactionRecordId
                                </td>
                                <td class="govuk-table__cell"
                                    data-testid="integration-transaction-record:@result.IntegrationTransactionRecordId:personid">
                                    <a class="govuk-link" href="row?integrationtransactionrecordid=@result.IntegrationTransactionRecordId"> @result.PersonName</a>
                                </td>
                                <td class="govuk-table__cell"
                                    data-testid="integration-transaction-record:@result.IntegrationTransactionRecordId:duplicate">

                                    @if (result.Duplicate == true)
                                    {
                                        <tag color="TagColor.Orange" class="govuk-!-static-padding-1">Duplicate</tag>
                                    }
                                </td>
                                <td class="govuk-table__cell"
                                    data-testid="integration-transaction-record:@result.IntegrationTransactionRecordId:status">
                                    @if (result.Status == IntegrationTransactionRecordStatus.Success)
                                    {
                                        <tag color="TagColor.Green" class="govuk-!-static-padding-1">@result.Status.GetDisplayName()</tag>
                                    }
                                    else @if (result.Status == IntegrationTransactionRecordStatus.Warning)
                                    {
                                        <tag color="TagColor.Yellow" class="govuk-!-static-padding-1">@result.Status.GetDisplayName()</tag>
                                    }
                                    else @if (result.Status == IntegrationTransactionRecordStatus.Failure)
                                    {
                                        <tag color="TagColor.Red" class="govuk-!-static-padding-1">@result.Status.GetDisplayName()</tag>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

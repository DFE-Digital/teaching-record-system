@page "/support-tasks/npq-trn-requests/{supportTaskReference}/no-matches/check-answers/{handler?}"
@model TeachingRecordSystem.SupportUi.Pages.SupportTasks.NpqTrnRequests.NoMatches.CheckAnswersModel
@{
    ViewBag.Title = "Check details before creating record";

    var backLink = LinkGenerator.SupportTasks.NpqTrnRequests.Details(Model.SupportTaskReference!, createRecord: true);
    var confirmButtonLabel = "Confirm and create record";
}

@section BeforeContent {
    <govuk-back-link href="@backLink" />
}

<form action="@LinkGenerator.SupportTasks.NpqTrnRequests.NoMatches.CheckAnswers(Model.SupportTaskReference!)" method="post">
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            <span class="govuk-caption-l">TRN requests</span>
            <h1 class="govuk-heading-l">@ViewBag.Title</h1>
        </div>
    </div>

    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            <govuk-summary-card data-testid="request">
                <title>
                    Details of the record
                </title>
                <govuk-summary-list>
                    <row>
                        <key>First name</key>
                        <value use-empty-fallback>@Model.FirstName</value>
                    </row>
                    <row>
                        <key>Middle name</key>
                        <value use-empty-fallback>@Model.MiddleName</value>
                    </row>
                    <row>
                        <key>Last name</key>
                        <value use-empty-fallback>@Model.LastName</value>
                    </row>
                    <row>
                        <key>Date of birth</key>
                        <value use-empty-fallback>@Model.DateOfBirth?.ToString(WebConstants.DateOnlyDisplayFormat)</value>
                    </row>
                    <row>
                        <key>Email</key>
                        <value use-empty-fallback>@Model.EmailAddress</value>
                    </row>
                    <row>
                        <key>National Insurance number</key>
                        <value use-empty-fallback>@Model.NationalInsuranceNumber</value>
                    </row>
                </govuk-summary-list>
            </govuk-summary-card>
            <div class="govuk-button-group">
                <govuk-button type="submit" data-testid="submit">@confirmButtonLabel</govuk-button>
                <govuk-button type="submit" formaction="@LinkGenerator.SupportTasks.NpqTrnRequests.NoMatches.CheckAnswersCancel(Model.SupportTaskReference!)" class="govuk-button--secondary">Cancel</govuk-button>
            </div>
        </div>
    </div>
</form>

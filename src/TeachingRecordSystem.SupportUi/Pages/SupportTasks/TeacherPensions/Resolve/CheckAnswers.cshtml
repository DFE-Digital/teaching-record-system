@page "/support-tasks/teacher-pensions/{supportTaskReference}/resolve/check-answers/{handler?}"
@model TeachingRecordSystem.SupportUi.Pages.SupportTasks.TeacherPensions.Resolve.CheckAnswersModel
@{
    ViewBag.Title = "Check details before merging records";
    var changeLink = LinkGenerator.SupportTasks.TeacherPensions.Resolve.Matches(Model.SupportTaskReference, Model.JourneyInstance!.InstanceId, fromCheckAnswers: true);
    var confirmButtonLabel = "Confirm and merge records";
}

@section BeforeContent {
    <govuk-back-link href="@LinkGenerator.SupportTasks.TeacherPensions.Resolve.Merge(Model.SupportTaskReference!, Model.JourneyInstance!.InstanceId)" />
}

<form method="post">
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            <span class="govuk-caption-l">Third-party tasks</span>
            <h1 class="govuk-heading-l">@ViewBag.Title</h1>
        </div>
    </div>

    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            <govuk-summary-list>
                <row>
                    <key>First name</key>
                    <value use-empty-fallback>@Model.FirstName</value>
                    @if (Model.IsFirstNameChangeable)
                    {
                        <row-actions>
                            <action href="@changeLink" data-testid="firstname-change-link" visually-hidden-text="first name">Change</action>
                        </row-actions>
                    }
                </row>
                <row>
                    <key>Last name</key>
                    <value use-empty-fallback>@Model.LastName</value>
                    @if (Model.IsLastNameChangeable)
                    {
                        <row-actions>
                            <action href="@changeLink" data-testid="lastname-change-link" visually-hidden-text="last name">Change</action>
                        </row-actions>
                    }
                </row>
                <row>
                    <key>TRN</key>
                    <value>@Model.Trn</value>
                </row>
                <row>
                    <key>Date of birth</key>
                    <value use-empty-fallback>@Model.DateOfBirth?.ToString(WebConstants.DateDisplayFormat)</value>
                    @if (Model.IsDateOfBirthChangeable)
                    {
                        <row-actions>
                            <action href="@changeLink" data-testid="dob-change-link" visually-hidden-text="date of birth">Change</action>
                        </row-actions>
                    }
                </row>
                <row>
                    <key>NI number</key>
                    <value use-empty-fallback>@Model.NationalInsuranceNumber</value>
                    @if (Model.IsNationalInsuranceNumberChangeable)
                    {
                        <row-actions>
                            <action href="@changeLink" data-testid="ni-change-link" visually-hidden-text="national insurance number">Change</action>
                        </row-actions>
                    }
                </row>
                <row>
                    <key>Evidence</key>
                    <value use-empty-fallback>
                        <vc:evidence-file-link evidence-file="@Model.EvidenceFile" />
                    </value>
                    <row-actions>
                        <action href="@changeLink" data-testid="evidence-change-link" visually-hidden-text="evidence">Change</action>
                    </row-actions>
                </row>
                <row>
                    <key>Comments</key>
                    <value use-empty-fallback>@Model.MergeComments</value>
                    <row-actions>
                        <action href="@changeLink" data-testid="comments-change-link" visually-hidden-text="comments">Change</action>
                    </row-actions>
                </row>
            </govuk-summary-list>
            <div class="govuk-button-group">
                <govuk-button type="submit" data-testid="submit">@confirmButtonLabel</govuk-button>
                <govuk-button type="submit" formaction="@LinkGenerator.SupportTasks.TeacherPensions.Resolve.CheckAnswersCancel(Model.SupportTaskReference, Model.JourneyInstance!.InstanceId, false)" class="govuk-button--secondary">Cancel</govuk-button>
            </div>
        </div>
    </div>
</form>

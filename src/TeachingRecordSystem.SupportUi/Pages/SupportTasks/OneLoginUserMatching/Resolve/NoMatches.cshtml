@page "/support-tasks/one-login-user-matching/{supportTaskReference}/resolve/no-matches"
@model TeachingRecordSystem.SupportUi.Pages.SupportTasks.OneLoginUserMatching.Resolve.NoMatches
@{
    ViewBag.Title = "We cannot find a record that matches this GOV.UK One Login";
}

@section BeforeContent {
    <govuk-back-link href="@Model.BackLink" />
}

<form method="post">
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            <span class="govuk-caption-l">Record management</span>
            <h1 class="govuk-heading-l">@ViewBag.Title</h1>

            <p class="govuk-body">
                You’ve verified @(Model.Name)’s identity, but we could not match their details to an existing teaching record.
            </p>

            @if (!string.IsNullOrWhiteSpace(Model.NoMatchesPageContent))
            {
                @Html.Raw(Model.NoMatchesPageContent)
            }
            else
            {
                <p class="govuk-body">
                    We’ll send them an email confirming we could not find a teaching record matching their GOV.UK One Login and asking them to check their details.
                </p>
            }

            <div class="govuk-button-group">
                <govuk-button type="submit">Confirm</govuk-button>
                <govuk-button type="submit" name="Cancel" value="true" class="govuk-button--secondary">Cancel</govuk-button>
            </div>
        </div>
    </div>
</form>

@page "/mqs/{qualificationId}/delete/check-answers/{handler?}"
@model TeachingRecordSystem.SupportUi.Pages.Mqs.DeleteMq.CheckAnswersModel
@{
    ViewBag.Title = "Check details before deleting mandatory qualification";
}

@section BeforeContent {
    <govuk-back-link href="@LinkGenerator.Mqs.DeleteMq.Index(Model.QualificationId, Model.JourneyInstance!.InstanceId)">Back</govuk-back-link>
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <form method="post">
            <span class="govuk-caption-l">Delete mandatory qualification - @Model.PersonName</span>
            <h1 class="govuk-heading-l" data-testid="title">@ViewBag.Title</h1>

            <govuk-summary-list data-testid="deletion-summary">
                <row>
                    <key>Training provider</key>
                    <value data-testid="provider">@(Model.ProviderName ?? "None")</value>
                </row>
                <row>
                    <key>Specialism</key>
                    <value data-testid="specialism">@(Model.Specialism?.GetTitle() ?? "None")</value>
                </row>
                <row>
                    <key>Status</key>
                    <value data-testid="status">@(Model.Status.HasValue ? Model.Status : "None")</value>
                </row>
                <row>
                    <key>Start date</key>
                    <value data-testid="start-date">@(Model.StartDate.HasValue ? Model.StartDate.Value.ToString("d MMMM yyyy") : "None")</value>
                </row>
                <row>
                    <key>End date</key>
                    <value data-testid="end-date">@(Model.EndDate.HasValue ? Model.EndDate.Value.ToString(WebConstants.DateDisplayFormat) : "None")</value>
                </row>
            </govuk-summary-list>
            <h2 class="govuk-heading-m">Why are you deleting this mandatory qualification?</h2>
            <govuk-summary-list data-testid="change-reason-summary">
                <row>
                    <key>Reason</key>
                    <value data-testid="deletion-reason">@Model.DeletionReason!.GetDisplayName()</value>
                </row>
                <row>
                    <key>Additional information</key>
                    <value data-testid="deletion-reason-detail">
                        @Html.ConvertNewlinesToLineBreaks(!string.IsNullOrEmpty(Model.DeletionReasonDetail) ? Model.DeletionReasonDetail : "None")
                    </value>
                </row>
                <row>
                    <key>Evidence</key>
                    <value data-testid="evidence">
                        <vc:evidence-file-link evidence-file="@Model.EvidenceFile" />
                    </value>
                </row>
            </govuk-summary-list>
            <h2 class="govuk-heading-m">Are you sure you want to delete this mandatory qualification?</h2>
            <div class="govuk-button-group">
                <govuk-button class="govuk-button--warning" type="submit">Confirm and delete qualification</govuk-button>
                <govuk-button formaction="@LinkGenerator.Mqs.DeleteMq.CheckAnswersCancel(Model.QualificationId, Model.JourneyInstance!.InstanceId)" class="govuk-button--secondary" type="submit">Cancel and return to record</govuk-button>
            </div>
        </form>
    </div>
</div>

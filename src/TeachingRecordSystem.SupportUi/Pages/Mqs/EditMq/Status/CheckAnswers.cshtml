@page "/mqs/{qualificationId}/status/check-answers/{handler?}"
@model TeachingRecordSystem.SupportUi.Pages.Mqs.EditMq.Status.CheckAnswersModel
@{
    ViewBag.Title = "Check details before editing mandatory qualification";
}

@section BeforeContent {
    <govuk-back-link href="@LinkGenerator.Mqs.EditMq.Status.Reason(Model.QualificationId, Model.JourneyInstance!.InstanceId)" />
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <form method="post">
            <span class="govuk-caption-l">Edit mandatory qualification - @Model.PersonName</span>
            <h1 class="govuk-heading-l" data-testid="title">@ViewBag.Title</h1>

            <govuk-summary-list data-testid="change-summary">
                @if (Model.IsStatusChange)
                {
                    <row>
                        <key>New status</key>
                        <value data-testid="new-status">@(Model.NewStatus.HasValue ? Model.NewStatus.Value.GetTitle() : "None")</value>
                    </row>
                    <row>
                        <key>Previous status</key>
                        <value data-testid="current-status">@(Model.CurrentStatus.HasValue ? Model.CurrentStatus.Value.GetTitle() : "None")</value>
                    </row>
                }
                @if (Model.IsEndDateChange)
                {
                    <row>
                        <key>New end date</key>
                        <value data-testid="new-end-date">@(Model.NewEndDate.HasValue ? Model.NewEndDate!.Value.ToString(WebConstants.DateDisplayFormat) : "None")</value>
                    </row>
                    <row>
                        <key>Previous end date</key>
                        <value data-testid="current-end-date">@(Model.CurrentEndDate.HasValue ? Model.CurrentEndDate!.Value.ToString(WebConstants.DateDisplayFormat) : "None")</value>
                    </row>
                }
            </govuk-summary-list>
            <h2 class="govuk-heading-m">Why are you editing this mandatory qualification?</h2>
            <govuk-summary-list data-testid="change-reason-summary">
                <row>
                    <key>Reason</key>
                    @if (Model.IsEndDateChange && !Model.IsStatusChange)
                    {
                        <value data-testid="change-reason">@Model.EndDateChangeReason!.GetDisplayName()</value>
                    }
                    else
                    {
                        <value data-testid="change-reason">@Model.StatusChangeReason!.GetDisplayName()</value>
                    }
                </row>
                <row>
                    <key>More details</key>
                    <value data-testid="change-reason-detail">@Html.ConvertNewlinesToLineBreaks(!string.IsNullOrEmpty(Model.ChangeReasonDetail) ? Model.ChangeReasonDetail : "None")</value>
                </row>
                <row>
                    <key>Evidence</key>
                    <value data-testid="evidence">
                        <vc:evidence-file-link evidence-file="@Model.EvidenceFile" />
                    </value>
                </row>
            </govuk-summary-list>

            <div class="govuk-button-group">
                <govuk-button type="submit">Confirm and update qualification</govuk-button>
                <govuk-button formaction="@LinkGenerator.Mqs.EditMq.Status.CheckAnswersCancel(Model.QualificationId, Model.JourneyInstance!.InstanceId)" class="govuk-button--secondary" type="submit">Cancel and return to record</govuk-button>
            </div>
        </form>
    </div>
</div>

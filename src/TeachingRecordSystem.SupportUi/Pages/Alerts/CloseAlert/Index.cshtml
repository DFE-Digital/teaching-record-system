@page "/alerts/{alertId}/close"
@model TeachingRecordSystem.SupportUi.Pages.Alerts.CloseAlert.IndexModel
@{
}

@section BeforeContent {
    @if (Model.BackLink is not null)
    {
        <govuk-back-link href="@Model.BackLink">Back</govuk-back-link>
    }
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <form method="post">
            <span class="govuk-caption-l">Close alert -@Model.PersonName</span>

            <govuk-date-input for="EndDate" error-message-prefix="Alert end date">
                <govuk-date-input-fieldset>
                    <govuk-date-input-fieldset-legend is-page-heading="true" class="govuk-fieldset__legend--l">
                        Enter an alert end date
                    </govuk-date-input-fieldset-legend>
                    <govuk-date-input-hint>For example 31 3 2024</govuk-date-input-hint>
                </govuk-date-input-fieldset>
            </govuk-date-input>

            <div class="govuk-button-group">
                <govuk-button type="submit">Continue</govuk-button>
                <govuk-button name="Cancel" value="true" class="govuk-button--secondary" type="submit">Cancel and return to record</govuk-button>
            </div>
        </form>
    </div>
</div>

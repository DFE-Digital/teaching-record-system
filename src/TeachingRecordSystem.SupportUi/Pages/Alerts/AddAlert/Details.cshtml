@page "/alerts/add/details"
@model TeachingRecordSystem.SupportUi.Pages.Alerts.AddAlert.DetailsModel
@{
    ViewBag.Title = "Enter details about this alert (optional)";
}

@section BeforeContent {
    @if (Model.BackLink is not null)
    {
        <govuk-back-link href="@Model.BackLink" />
    }
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <form method="post">
            <span class="govuk-caption-l">Add an alert - @Model.PersonName</span>
            <h1 class="govuk-heading-l">@ViewBag.Title</h1>
            <h2 class="govuk-heading-m">@Model.AlertTypeName</h2>
            <govuk-inset-text>
                <p>Do not enter details if the alert type is:</p>
                <ul class="govuk-list govuk-list--bullet">
                    <li>interim prohibition by the Secretary of State</li>
                    <li>prohibition by the Secretary of State - misconduct</li>
                    <li>Secretary of State decision - no prohibition</li>
                </ul>
            </govuk-inset-text>

            <govuk-character-count for="Details" max-length="UiDefaults.ReasonDetailsMaxCharacterCount" rows="UiDefaults.ReasonDetailsRows" data-testid="details">
                <govuk-character-count-label>Details</govuk-character-count-label>
                <govuk-character-count-hint>For example, include any restrictions it places on a teacher.</govuk-character-count-hint>
            </govuk-character-count>

            <div class="govuk-button-group">
                <govuk-button type="submit">Continue</govuk-button>
                <govuk-button name="Cancel" value="true" class="govuk-button--secondary" type="submit">Cancel and return to record</govuk-button>
            </div>
        </form>
    </div>
</div>
